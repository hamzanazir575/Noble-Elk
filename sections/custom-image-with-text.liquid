<style>

  .product-feature {
    background-color: #f3f3f3;
    padding: 60px 0;
  }

  .page-width {
    padding: 0;
  }

  .product-feature__wrapper {
    display: flex;
    flex-direction: column;
    text-align: center;
    align-items: center;
    justify-content: space-between;
    gap: 30px;
  }

  .product-feature__image-column {
    flex: 1;
  }

  .product-feature__content-column {
    flex: 1;
    display: flex;
    justify-content: center;
    flex-direction: column;
    gap: 16px;
    padding: 40px;
  }

  .product-feature__image {
    width: 100%;
    height: 100%;
    display: block;
    margin: 0 auto;
  }

  .product-feature__badge {
    display: inline-block;
    width: fit-content;
    background: #121212;
    color: #fff;
    padding: 10px 18px;
    font-size: 12px;
    font-weight: 600;
    border-radius: 4px;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    margin-inline: auto;
  }

  .product-feature__heading {
    font-size: 2.8rem;
    line-height: 1.2;
    color: #121212;
    font-weight: 400;
    margin: 0;
  }

  .product-feature__subheading {
    font-size: 1.8rem;
    font-weight: bolder;
    color: #121212;
    line-height: 1.6;
    margin-block: 16px;
  }

  .product-feature__description {
    font-size: 1.5rem;
    line-height: 1.7;
    color: #121212;
    letter-spacing: 0.4px;
    margin-bottom: 16px;
  }

  .product-feature__button {
    display: inline-block;
    width: fit-content;
    min-width: 140px;
    min-height: 46px;
    padding: 14px 28px;
    background-color: #03751d;
    color: #ffffff;
    text-decoration: none;
    border-radius: 6px;
    font-size: 1.5rem;
    font-weight: 600;
    text-align: center;
  }

  .product-feature__button:hover {
    background: #333333;
  }

  /* ---------- Tablet ---------- */

  @media screen and (min-width: 768px) {

    .product-feature__heading {
      font-size: 3.2rem;
    }

    .product-feature__subheading {
      font-size: 2rem;
    }

    .product-feature__description {
      font-size: 1.6rem;
    }

    .product-feature__button {
      min-width: 150px;
      min-height: 50px;
    }
  }

  /* ---------- Large Tablet ---------- */

  @media screen and (min-width: 990px) {

    .product-feature__wrapper {
      flex-direction: row;
      text-align: left;
    }

    .product-feature__badge {
      margin-inline: 0;
    }

    .product-feature__heading {
      font-size: 36px;
    }

    .product-feature__subheading {
      font-size: 2.2rem;
    }

    .product-feature__description {
      font-size: 1.7rem;
    }
  }

  /* ---------- Desktop ---------- */

  @media screen and (min-width: 1200px) {

    .product-feature__wrapper {
      gap: 50px;
    }

    .product-feature__heading {
      font-size: 36px;
    }

    .product-feature__badge {
      font-size: 20px;
      padding: 8px 12px;
    }
  }

</style>


<section class="product-feature">
  <div class="page-width">
    <div class="product-feature__wrapper">

      <div class="product-feature__image-column">
        {% if section.settings.image != blank %}
          <img
            src="{{ section.settings.image | image_url: width: 1200 }}"
            width="4000"
            height="4000"
            alt="{{ section.settings.heading | escape }}"
            class="product-feature__image"
            loading="lazy">
        {% endif %}
      </div>

      <div class="product-feature__content-column">

        {% if section.settings.badge != blank %}
          <span class="product-feature__badge">
            {{ section.settings.badge }}
          </span>
        {% endif %}

        {% if section.settings.heading != blank %}
          <h2 class="product-feature__heading">
            {{ section.settings.heading }}
          </h2>
        {% endif %}

        {% if section.settings.subheading != blank %}
          <h3 class="product-feature__subheading">
            {{ section.settings.subheading }}
          </h3>
        {% endif %}

        {% if section.settings.description != blank %}
          <div class="product-feature__description">
            {{ section.settings.description }}
          </div>
        {% endif %}

        {% if section.settings.button_label != blank and section.settings.button_link != blank %}
          <a href="{{ section.settings.button_link }}" class="product-feature__button">
            {{ section.settings.button_label }}
          </a>
        {% endif %}

      </div>

    </div>
  </div>
</section>

{% schema %}
  {
    "name": "Product Feature",
    "tag": "section",
    "class": "section",

    "settings": [
      {
        "type": "image_picker",
        "id": "image",
        "label": "Product Image"
      },

      {
        "type": "text",
        "id": "badge",
        "label": "Badge",
        "default": "NEW RELEASE"
      },

      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "Freeze-Dried Elk Organ Treats"
      },

      {
        "type": "text",
        "id": "subheading",
        "label": "Sub Heading",
        "default": "From Our Herd to your Pack"
      }, {
        "type": "richtext",
        "id": "description",
        "label": "Description",
        "default": "<p>Made from 100% farm-raised elk organs. Freeze-dried to preserve natural flavor and nutrients, these primal treats deliver an exciting alternative to everyday dog snacks.</p>"
      }, {
        "type": "text",
        "id": "button_label",
        "label": "Button Label",
        "default": "Buy Now"
      }, {
        "type": "url",
        "id": "button_link",
        "label": "Button Link"
      }
    ],

    "presets": [
      {
        "name": "Custom Product Feature With Text"
      }
    ]
  }
{% endschema %}