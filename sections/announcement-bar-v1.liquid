<div
  id="promo-banner"
  class="bg-banner font-circular leading-[2] pt-[2px] pb-[3px] px-1 text-base text-center text-dark-green w-full"
  data-announcement-bar
>
  {% for block in section.blocks %}
    <div
      class="banner-message {% unless forloop.first %}banner-message-hidden{% endunless %}"
      {{ block.shopify_attributes }}
    >
      <div class="hidden lg:block">
        <p>
          {% if block.settings.url != blank %}
            {{ block.settings.text }}
            <a class="underline" href="{{ block.settings.url }}">
              {{ block.settings.link_text }}
            </a>
          {% else %}
            {{ block.settings.text }}
          {% endif %}
        </p>
      </div>
      <div class="block lg:hidden">
        <p>
          {% if block.settings.url != blank %}
            <a href="{{ block.settings.url }}">{{ block.settings.text }}</a>
          {% else %}
            {{ block.settings.text }}
          {% endif %}
        </p>
      </div>
    </div>
  {% endfor %}
</div>

{% schema %}
{
  "name": "Announcement Bar V1",
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Message",
          "default": "Free Shipping over $125 🚚"
        },
        {
          "type": "text",
          "id": "link_text",
          "label": "Link text",
          "default": "Shop Giant Plants"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link URL"
        }
      ]
    }
  ],
  "presets": [
    { "name": "Announcement Bar V1" }
  ]
}
{% endschema %}