<style>
  .featured-collection-v1 {
    background-color: rgb(185 161 108 / 9%);
  }

  .featured-collection-v1__container {
    padding-block: 93px 203px;
    max-width: 1230px;
    margin: 0 auto;
  }

  .featured-collection-v1__header {
    text-align: center;
  }

  .featured-collection-v1__heading {
    margin: 0 0 24px;
    font-size: 20px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.6px;
  }

  .featured-collection-v1__heading::after {
    content: "";
    display: block;
    width: 40px;
    height: 4px;
    background: #cda34f;
    margin: 16px auto 0;
  }

  .featured-collection-v1__grid {
    display: grid;
    gap: 16px;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: repeat(4, 200px);
    width: 100%;
    grid-template-areas: "item1 item1" "item2 item2" "item3 item3" "item4 item4";
  }

  .featured-collection-v1__grid img {
    width: 100%;
    height: 100%;
  }

  .featured-collection-v1__item {
    position: relative;
    overflow: hidden;
  }

  .featured-collection-v1__item--1 {
    grid-area: item1;
  }

  .featured-collection-v1__item--2 {
    grid-area: item2;
  }

  .featured-collection-v1__item--3 {
    grid-area: item3;
  }

  .featured-collection-v1__item--4 {
    grid-area: item4;
  }

  .featured-collection-v1__image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .featured-collection-v1__item::before {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, {{ section.settings.overlay_opacity | divided_by: 100.0 }});
    z-index: 1;
    transition: background 0.3s ease;
  }

  .featured-collection-v1__item:hover .featured-collection-v1__image {
    transform: scale(1.05);
  }

  .featured-collection-v1__item:hover::before {
    background: rgba(0, 0, 0, 0.6);
  }

  .featured-collection-v1__content {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 20px;
  }

  .featured-collection-v1__title {
    font-size: 32px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin: 0;
  }

  @media screen and (min-width: 1024px) {
    .featured-collection-v1__container {
      padding-block: 82px 203px;
    }

    .featured-collection-v1__grid {
      grid-template-columns: 255px 1fr 1fr 1fr;
      grid-template-rows: repeat(2, 250px);
      gap: 20px;
      grid-template-areas: "item1 item1 item2 item3" "item1 item1 item4 item4";
    }

    .featured-collection-v1__title {
      font-size: 32px;
    }

    .featured-collection-v1__heading {
      color: {{ section.settings.heading_text_color }};
      margin-bottom: 48px;
      font-size: 24px;
    }
  }
</style>

<div class="featured-collection-v1__container">
  <div class="featured-collection-v1__header">
    <h2 class="featured-collection-v1__heading">
      {{ section.settings.heading }}
    </h2>
  </div>
  <div class="featured-collection-v1__grid">
    {% for block in section.blocks %}

      {% assign collection = block.settings.collection %}

      {% if collection != blank %}
        <a href="{{ collection.url }}" class="featured-collection-v1__item featured-collection-v1__item--{{ forloop.index }}">

          {% if collection.featured_image %}
            <img
              class="featured-collection-v1__image"
              src="{{ collection.featured_image | image_url: width: collection.featured_image.width}}"
              alt="{{ collection.title }}"
              loading="lazy"
              width="{{collection.featured_image.width}}"
              height="{{collection.featured_image.height}}">
          {% endif %}

          <div class="featured-collection-v1__content">
            <h3 style="color:{{ block.settings.title_text_color }};" class="featured-collection-v1__title">

              {% if block.settings.custom_title != blank %}
                {{ block.settings.custom_title }}
              {% else %}
                {{ collection.title }}
              {% endif %}

            </h3>
          </div>
        </a>

      {% else %}
        <div class="featured-collection-v1__item featured-collection-v1__item--{{ forloop.index }}">

          {{ 'collection-1' | placeholder_svg_tag: 'featured-collection-v1__image' }}

          <div class="featured-collection-v1__content">
            <h3 class="featured-collection-v1__title">
              Collection Title
            </h3>
          </div>
        </div>

      {% endif %}

    {% endfor %}
  </div>
</div>

{% schema %}
  {
    "name": "Featured Collection v1",
    "tag": "section",
    "class": "featured-collection-v1",
    "settings": [
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "Featured Collections"
      },
      {
        "type": "color",
        "id": "heading_text_color",
        "label": "Heading Text Color",
        "default": "#000000"
      },
      {
        "type": "range",
        "id": "overlay_opacity",
        "label": "Overlay Opacity",
        "min": 0,
        "max": 100,
        "step": 5,
        "unit": "%",
        "default": 50
      }
    ],
    "blocks": [
      {
        "type": "collection",
        "name": "Collection",
        "settings": [
          {
            "type": "collection",
            "id": "collection",
            "label": "Select Collection"
          },
          {
            "type": "text",
            "id": "custom_title",
            "label": "Title"
          }, 
          {
            "type": "color",
            "id": "title_text_color",
            "label": "Title Text Color",
            "default": "#fff"
          }
        ]
      }
    ],
    "max_blocks": 4,
    "presets": [
      {
        "name": "Featured Collection v1",
        "blocks": [
          {
            "type": "collection"
          },
          {
            "type": "collection"
          },
          {
            "type": "collection"
          },
          {
            "type": "collection"
          }
        ]
      }
    ]
  }
{% endschema %}