<style>
  .faq {
    background-color: #f8f6f1;
  }

  .faq-container {
    display: flex;
    align-items: normal;
    gap: 78px;
  }

  .faq-image {
    width: 50%;
  }

  .faq-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .faq-content {
    width: 50%;
    padding: 154px 40px;
  }

  .faq-heading {
    font-size: 21px;
    font-weight: 550;
    letter-spacing: 0.81px;
    text-transform: uppercase;
    color: #1c1c1c;
    margin: 0;
    margin-bottom: 49px;
    padding-bottom: 27px;
    position: relative;
  }

  .faq-heading::after {
    content: "";
    width: 47px;
    height: 4px;
    background-color: #005b22;
    position: absolute;
    left: 0;
    bottom: 0;
  }

  .faq-item {
    border-bottom: 1px solid #dddddd;
    padding-bottom: 20px;
    line-height: 1.8;
  }

  .faq-question {
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
  }

  .faq-question h3 {
    font-size: 15px;
    font-weight: 650;
    text-transform: uppercase;
    padding: 28px 0 18px 0;
    margin: 0;
    color: #1c1c1c;
  }

  .faq-icon {
    color: #b38622;
    font-size: 42px;
    font-weight: 300;
    line-height: 1;
    flex-shrink: 0;
  }

  .faq-answer {
    max-height: 0;
    width: 100%;
    overflow: hidden;
    transition: max-height .4s ease;
  }

  .faq-answer p {
    margin-bottom: 18px;
    font-size: 14px;
    color: #444;
  }

  .faq-item.active .faq-answer {
    max-height: 300px;
  }

  .faq-button {
    color: {{ section.settings.btn_font_color }};
    text-transform: uppercase;
    padding-block: 14px;
    text-decoration: none;
    font-size: 14px;
    font-weight: 650;
    text-align: center;
    transition: color 0.3s ease;
    display: inline-block;
    margin-top: 75px;
  }

  .faq-button:hover {
    color: #946d16;
  }

  @media screen and (min-width: 1117px) {
  .faq-container {
    align-items: center;
  }
}

  @media screen and (max-width: 992px) {
    .faq-container {
      flex-direction: column;
    }

    .faq-image,
    .faq-content {
      width: 100%;
    }

    .faq-content {
      padding: 40px 20px;
    }

    .faq-heading {
      margin-bottom: 60px;
    }
  }

</style>

<div class="faq">
  <div class="faq-container">
    <div class="faq-image">
      {% if section.settings.image != blank %}
        <img 
          src="{{ section.settings.image | image_url: width: section.settings.image.width, height: section.settings.image.height }}"
          alt="{{ section.settings.image.alt }}"
          loading="lazy">
          {% else %}
            {{ 'product-1' | placeholder_svg_tag }}
      {% endif %}
    </div>
    <div class="faq-content">
      {% if section.settings.heading != blank %}
        <h2 class="faq-heading">
          {{ section.settings.heading }}
        </h2>
      {% endif %}

      {% for block in section.blocks %}
        <div class="faq-item {% if forloop.first %}active{% endif %}" 
             {{ block.shopify_attributes }}>
          <div class="faq-question">
            <h3>
              {{ block.settings.question }}
            </h3>
            <span class="faq-icon">
              {% if forloop.first %}
                −
              {% else %}
                +
              {% endif %}
            </span>
          </div>
          <div class="faq-answer">
            <p>
              {{ block.settings.answer }}
            </p>
          </div>
        </div>
      {% endfor %}

      {% if section.settings.button_label != blank and section.settings.button_link != blank %}
        <a class="faq-button" href="{{ section.settings.button_link }}">
          {{ section.settings.button_label }}
        </a>
      {% endif %}

    </div>
  </div>
</div>

<script>
  document.querySelectorAll('.faq-item').forEach(function(item) {
    item.classList.remove('active')
    item.querySelector('.faq-icon').textContent = '+'
  });

  document.querySelectorAll(".faq-question").forEach(function(question) {

    question.addEventListener("click", function() {
      const item = this.parentElement;
      const icon = this.querySelector(".faq-icon");

      if (item.classList.contains("active")) {
        item.classList.remove("active");
        icon.textContent = "+";
      } else {
        item.classList.add("active");
        icon.textContent = "−";
      }

    });
  });
</script>

{% schema %}
{
  "name": "FAQs",
  "tag": "section",
  "class": "faq",

  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "FAQ Image"
    },

    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "view all faq"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "color",
      "id": "btn_font_color",
      "label": "Button Text Color",
      "default": "#b88921"
    }
  ],


  "blocks": [
    {
      "type": "faq",
      "name": "FAQ",

      "settings": [

        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Write your question"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer",
          "default": "Write your answer here"
        },
      ]
    }
  ],


  "presets": [
    {
      "name": "FAQs",

      "blocks": [
        {
          "type": "faq"
        },
        {
          "type": "faq"
        },
        {
          "type": "faq"
        }
      ]
    }
  ]

}
{% endschema %}