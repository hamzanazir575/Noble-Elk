<style>
  .faqs {
    background-color: #f8f6f1;
  }

  .faqs__container {
    display: flex;
    flex-direction: column;
    align-items: normal;
    gap: 78px;
  }

  .faqs__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .faqs__content {
    width: 100%;
    padding: 40px 20px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .faqs__heading {
    font-size: 21px;
    font-weight: 550;
    letter-spacing: 0.81px;
    text-transform: uppercase;
    color: #1c1c1c;
    margin: 0;
    margin-bottom: 49px;
    padding-bottom: 27px;
    position: relative;
    line-height: 1.8;
  }

  .faqs__heading::after {
    content: "";
    width: 47px;
    height: 4px;
    background-color: #005b22;
    position: absolute;
    left: 0;
    bottom: 0;
  }

  .faqs__item {
    border-bottom: 1px solid #dddddd;
    margin-bottom: 18px;
  }

  .faqs__question {
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
  }

  .faqs__question h3 {
    font-size: 15px;
    font-weight: 650;
    text-transform: uppercase;
    padding: 28px 0 18px 0;
    margin: 0;
    color: #1c1c1c;
    line-height: 1.8;
  }

  .faqs__icon {
    color: #b38622;
    width: 17px;
    height: 17px;
  }

  .faqs__answer {
    max-height: 0;
    width: 100%;
    overflow: hidden;
    transition: max-height .4s ease;
  }

  .faqs__answer p {
    margin-bottom: 18px;
    font-size: 14px;
    color: #444;
    line-height: 1.8;
  }

  .faqs__item.active .faqs__answer {
    max-height: 300px;
  }

  .faqs__button {
    color: {{ section.settings.btn_font_color }};
    text-transform: uppercase;
    padding-block: 14px;
    text-decoration: none;
    font-size: 14px;
    font-weight: 650;
    transition: color 0.3s ease;
    display: inline-block;
    margin-top: 75px;
  }

  .faqs__button:hover {
    color: #946d16;
  }

  @media screen and (min-width: 993px) {
    .faqs__container {
      flex-direction: row;
    }

    .faqs__image,
    .faqs__content {
      width: 50%;
    }

    .faqs__content {
      padding: 154px 40px;
    }
  }
</style>

<div class="faqs">
  <div class="faqs__container">
    <div class="faqs__image">
      {% if section.settings.image != blank %}
        <img 
          src="{{ section.settings.image | image_url: width: section.settings.image.width, height: section.settings.image.height }}"
          alt="{{ section.settings.image.alt }}"
          loading="lazy">
          {% else %}
            {{ 'product-1' | placeholder_svg_tag }}
      {% endif %}
    </div>
    <div class="faqs__content">
      {% if section.settings.heading != blank %}
        <h2 class="faqs__heading">
          {{ section.settings.heading }}
        </h2>
      {% endif %}

      {% for block in section.blocks %}
        <div class="faqs__item {% if forloop.first %}active{% endif %}" 
             >
          <div class="faqs__question">
            <h3>
              {{ block.settings.question }}
            </h3>
            <span class="faqs__icon">
              {% if forloop.first %}
                  <svg width="17" height="17" viewBox="0 0 17 17" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect y="8" width="17" height="2" fill="#A77E24"></rect>
                  </svg>
                {% else %}
                  <svg width="17" height="17" viewBox="0 0 17 17" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect y="8" width="17" height="2" fill="#A77E24"></rect>
                    <rect x="9" width="17" height="2" transform="rotate(90 9 0)" fill="#A77E24"></rect>
                  </svg>
              {% endif %}
            </span>
          </div>
          <div class="faqs__answer">
            <p>
              {{ block.settings.answer }}
            </p>
          </div>
        </div>
      {% endfor %}

      {% if section.settings.button_label != blank and section.settings.button_link != blank %}
        <a class="faqs__button" href="{{ section.settings.button_link }}">
          {{ section.settings.button_label }}
          <svg width="8" height="11" viewBox="0 0 8 11" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M1.71655 1.02827L6.20636 5.94764L1.71655 10.2404" stroke="currentColor" stroke-width="2"></path>
          </svg>
        </a>
      {% endif %}

    </div>
  </div>
</div>

<script>

  const plusIcon = `
  <svg width="17" height="17" viewBox="0 0 17 17" fill="none">
    <rect y="8" width="17" height="2" fill="#A77E24"></rect>
    <rect x="9" width="17" height="2" transform="rotate(90 9 0)" fill="#A77E24"></rect>
  </svg>
`;

const minusIcon = `
  <svg width="17" height="17" viewBox="0 0 17 17" fill="none">
    <rect y="8" width="17" height="2" fill="#A77E24"></rect>
  </svg>
`;

  document.querySelectorAll(".faqs__question").forEach(function(question) {

    question.addEventListener("click", function() {
      const item = this.parentElement;
      const icon = this.querySelector(".faqs__icon");

      if (item.classList.contains("active")) {
        item.classList.remove("active");
        icon.innerHTML = plusIcon;
      } else {
        item.classList.add("active");
        icon.innerHTML = minusIcon;
      }
    });
  });
</script>

{% schema %}
{
  "name": "FAQs",
  "tag": "section",
  "class": "faqs",

  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "view all faq"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "color",
      "id": "btn_font_color",
      "label": "Button Text Color",
      "default": "#b88921"
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Write your question"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer",
          "default": "Write your answer here"
        },
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQs",

      "blocks": [
        {
          "type": "faq"
        },
        {
          "type": "faq"
        },
        {
          "type": "faq"
        }
      ]
    }
  ]
}
{% endschema %}