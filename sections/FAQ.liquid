<style>
  .faq-section {
    background-color: #f8f6f1;
  }

  .faq-container {
    display: flex;
    align-items: stretch;
  }

  .faq-image {
    width: 50%;
  }

  .faq-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .faq-content {
    width: 50%;
    padding: 120px 80px;
  }

  .faq-heading {
    font-size: 26px;
    font-weight: 400;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #1c1c1c;
    margin: 0 0 80px;
    position: relative;
  }

  .faq-heading::after {
    content: "";
    width: 55px;
    height: 4px;
    background-color: #0b6b30;
    position: absolute;
    left: 0;
    bottom: -25px;
  }

  .faq-item {
    border-bottom: 1px solid #dddddd;
    padding: 30px 0;
  }

  .faq-question {
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    gap: 20px;
  }

  .faq-question h3 {
    font-size: 18px;
    font-weight: 700;
    text-transform: uppercase;
    margin: 0;
    color: #111;
    letter-spacing: 0.5px;
  }

  .faq-icon {
    color: #b38622;
    font-size: 42px;
    font-weight: 300;
    line-height: 1;
    flex-shrink: 0;
  }

  .faq-answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height .4s ease;
  }

  .faq-answer p {
    margin: 25px 0 10px;
    font-size: 16px;
    line-height: 1.8;
    color: #555;
  }

  .faq-item.active .faq-answer {
    max-height: 300px;
  }


  @media screen and (max-width: 991px) {

    .faq-container {
      flex-direction: column;
    }

    .faq-image,
    .faq-content {
      width: 100%;
    }

    .faq-content {
      padding: 60px 25px;
    }

    .faq-heading {
      font-size: 22px;
      margin-bottom: 60px;
    }

    .faq-question h3 {
      font-size: 16px;
    }
  }

</style>

<div class="faq-section">
  <div class="faq-container">
    <div class="faq-image">
      {% if section.settings.image != blank %}
        <img 
          src="{{ section.settings.image | image_url: width: 2000 }}"
          alt="{{ section.settings.image.alt }}"
          loading="lazy">
      {% endif %}
    </div>
    <div class="faq-content">
      {% if section.settings.heading != blank %}
        <h2 class="faq-heading">
          {{ section.settings.heading }}
        </h2>
      {% endif %}

      {% for block in section.blocks %}
        <div class="faq-item {% if forloop.first %}active{% endif %}" 
             {{ block.shopify_attributes }}>
          <div class="faq-question">
            <h3>
              {{ block.settings.question }}
            </h3>
            <span class="faq-icon">
              {% if forloop.first %}
                −
              {% else %}
                +
              {% endif %}
            </span>
          </div>
          <div class="faq-answer">
            <p>
              {{ block.settings.answer }}
            </p>
          </div>
        </div>
      {% endfor %}

    </div>
  </div>
</div>

<script>
  document.querySelectorAll('.faq-item').forEach(function(item) {
    item.classList.remove('active')
    item.querySelector('.faq-icon').textContent = '+'
  });

  document.querySelectorAll(".faq-question").forEach(function(question) {

    question.addEventListener("click", function() {
      const item = this.parentElement;
      const icon = this.querySelector(".faq-icon");

      if (item.classList.contains("active")) {
        item.classList.remove("active");
        icon.textContent = "+";
      } else {
        item.classList.add("active");
        icon.textContent = "−";
      }

    });
  });
</script>

{% schema %}
{
  "name": "FAQ Section",
  "tag": "section",
  "class": "faq",

  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "FAQ Image"
    },

    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently Asked Questions"
    }
  ],


  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Item",

      "settings": [

        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Write your question"
        },

        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer",
          "default": "Write your answer here"
        }

      ]
    }
  ],


  "presets": [
    {
      "name": "FAQ Section",

      "blocks": [
        {
          "type": "faq_item"
        },
        {
          "type": "faq_item"
        },
        {
          "type": "faq_item"
        }
      ]
    }
  ]

}
{% endschema %}