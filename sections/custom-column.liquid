<style>

  .card__container {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    padding-inline: 20px;
    gap: 15px;
    width: 100%;
  }

  .card__image {
    text-align: center;
  }

  .card__image img {
    width: 60px;
    height: 60px;
    margin-bottom: 6px;
  }

  .card__text {
    margin-block: 14px;
    font-size: 14px;
    text-transform: uppercase;
    color: #121212;
    line-height: 1.5;
    font-weight: 400;
    letter-spacing: 0.6px;
  }

  @media screen and (min-width: 749px) {
    .card__container {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media screen and (min-width: 988px) {
    .card__container {
      grid-template-columns: repeat(5, 1fr);
      gap: 30px;
    }

  }

</style>
<div class="card">
  <div class="card__container">
    {% for block in section.blocks %}
      <div class="card__inner page-width">
        <div class="card__image">

          {% if block.settings.card_image != blank %}
            <img
              src="{{ block.settings.card_image | image_url: width: 60 }}"
              width="60"
              height="60"
              loading="lazy"
              alt="{{ block.settings.text }}">
          {% else %}
            {{ 'product-1' | placeholder_svg_tag }}
          {% endif %}

          {% if block.settings.text != blank %}
            <p class="card__text">
              {{ block.settings.text }}
            </p>
          {% endif %}

        </div>
      </div>
    {% endfor %}
  </div>
</div>

{% schema %}
  {
    "name": "Logo With Text",
    "tag": "section",
    "class": "section",

    "blocks": [
      {
        "type": "logo",
        "name": "Logo",
        "settings": [
          {
            "type": "image_picker",
            "id": "card_image",
            "label": "Logo"
          }, {
            "type": "text",
            "id": "text",
            "label": "Description",
            "default": "Write your text"
          }
        ]
      }
    ],

    "presets": [
      {
        "name": "Logo With Text",
        "blocks": [
          {
            "type": "logo"
          },
          {
            "type": "logo"
          },
          {
            "type": "logo"
          },
          {
            "type": "logo"
          }, {
            "type": "logo"
          }
        ]
      }
    ]
  }
{% endschema %}