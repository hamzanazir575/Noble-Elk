<style>
  .image-with-text-v1__container {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    gap: 40px;
    background-color: #f3f3f3;
  }

  .image-with-text-v1__container--image_first_mobile {
    flex-direction: column;
  }

  .image-with-text-v1__container--image_second_mobile {
    flex-direction: column-reverse;
  }

  .image-with-text-v1__image-column {
    flex: 0 0 45%;
  }
  
  .image-with-text-v1__image {
    width: 100%;
    height: 100%;
    display: block;
    margin: 0 auto;
  }
  
  .image-with-text-v1__content-column {
    display: flex;
    justify-content: center;
    align-items: flex-start;
    flex-direction: column;
    gap: 16px;
    padding: 30px;
  }


  .image-with-text-v1__badge {
    background: {{ section.settings.badge_background_color }};
    color: {{ section.settings.badge_font_color }};
    padding: 8px 12px;
    font-size: 20px;
    font-weight: 600;
    border-radius: 4px;
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }

  .image-with-text-v1__heading {
    color: {{ section.settings.heading_font_color }};
    font-size: 28.8px;
    line-height: 1.2;
    font-weight: 400;
    margin: 0;
  }

  .image-with-text-v1__subheading {
    color: {{ section.settings.subheading_font_color }};
    font-weight: 700;
    line-height: 1.6;
    margin-block: 16px 10px;
    font-size: 16px;
  }

  .image-with-text-v1__description {
    color: {{ section.settings.description_font_color }};
    font-size: 16px;
    line-height: 1.6;
    letter-spacing: 0.6px;
  }

  .image-with-text-v1__button {
    background-color: {{ section.settings.btn_bg_color }};
    color: {{ section.settings.btn_font_color }};
    padding: 15px 27px;
    text-decoration: none;
    border-radius: 6px;
    font-size: 12px;
    font-weight: 600;
    text-align: center;
    transition: background-color 0.3s ease
  }

  .image-with-text-v1__button:hover {
    background: #333333;
  }


  @media screen and (min-width: 748px) {

     .image-with-text-v1__container--image_first {
      flex-direction: row;
    }

    .image-with-text-v1__container--image_second {
      flex-direction: row-reverse;
    }


    .image-with-text-v1__container {
      gap: 40px;
    }

    .image-with-text-v1__content-column {
      padding: 40px;
    }

    .image-with-text-v1__heading {
      font-size: 36px;
    }

    .image-with-text-v1__subheading,
    .image-with-text-v1__description {
      font-size: 16px;
    }
  }
</style>


<div class="image-with-text-v1__container image-with-text-v1__container--{{ section.settings.layout }} image-with-text-v1__container--{{ section.settings.mobile_layout }}">
  <div class="image-with-text-v1__image-column">
    {% if section.settings.image != blank %}
      <img
        src="{{ section.settings.image | image_url: width: section.settings.image.width }}"
        width="4000"
        height="4000"
        alt="{{ section.settings.heading | escape }}"
        class="image-with-text-v1__image"
        loading="lazy">
    {% else %}
      {{ 'product-1' | placeholder_svg_tag }}
    {% endif %}

  </div>
  <div class="image-with-text-v1__content-column">
    {% if section.settings.badge != blank %}
      <span class="image-with-text-v1__badge">
        {{ section.settings.badge }}
      </span>
    {% endif %}

    {% if section.settings.heading != blank %}
      <h2 class="image-with-text-v1__heading">
        {{ section.settings.heading }}
      </h2>
    {% endif %}

    {% if section.settings.subheading != blank %}
      <h3 class="image-with-text-v1__subheading">
        {{ section.settings.subheading }}
      </h3>
    {% endif %}

    {% if section.settings.text != blank %}
      <p class="image-with-text-v1__description">
        {{ section.settings.text }}
      </p>
    {% endif %}

    {% if section.settings.button_label != blank and section.settings.button_link != blank %}
      <a href="{{ section.settings.button_link }}" class="image-with-text-v1__button">
        {{ section.settings.button_label }}
      </a>
    {% endif %}

  </div>
</div>

{% schema %}
  {
    "name": "Image With Text V1",
    "tag": "section",
    "class": "image-with-text-v1",
    "settings": [
      {
        "type": "image_picker",
        "id": "image",
        "label": "Product Image"
      },
      {
        "type": "select",
        "id": "layout",
        "label": "Image Position",
        "options": [
          {
            "value": "image_first",
            "label": "Image First"
          },
          {
            "value": "image_second",
            "label": "Image Second"
          }
        ],
        "default": "image_first"
      },
      {
        "type": "select",
        "id": "mobile_layout",
        "label": "Mobile Image Position",
        "options": [
          {
            "value": "image_first_mobile",
            "label": "Image First"
          },
          {
            "value": "image_second_mobile",
            "label": "Image Second"
          }
        ],
        "default": "image_first_mobile"
      },
      {
        "type": "text",
        "id": "badge",
        "label": "Badge",
        "default": "new release"
      },
      {
        "type": "color",
        "id": "badge_background_color",
        "label": "Badge Background Color",
        "default": "#121212"
      },
      {
        "type": "color",
        "id": "badge_font_color",
        "label": "Badge Text Color",
        "default": "#ffffff"
      },
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "Write heading here"
      },
      {
        "type": "color",
        "id": "heading_font_color",
        "label": "Heading Text Color",
        "default": "#121212"
      },
      {
        "type": "text",
        "id": "subheading",
        "label": "Sub Heading",
        "default": "Write subheading here"
      }, 
      {
        "type": "color",
        "id": "subheading_font_color",
        "label": "Subheading Text Color",
        "default": "#121212"
      },
      {
        "type": "text",
        "id": "text",
        "label": "Description",
        "default": "Write description here"
      },      
      {
        "type": "color",
        "id": "description_font_color",
        "label": "Description Text Color",
        "default": "#121212"
      },   
      {
        "type": "text",
        "id": "button_label",
        "label": "Button Label",
        "default": "Buy Now"
      }, 
      {
        "type": "color",
        "id": "btn_bg_color",
        "label": "Button Background Color",
        "default": "#121212"
      }, 
      {
        "type": "color",
        "id": "btn_font_color",
        "label": "Button Text Color",
        "default": "#ffffff"
      }, 
      {
        "type": "url",
        "id": "button_link",
        "label": "Button Link"
      }
    ],
    "presets": [
      {
        "name": "Image With Text V1"
      }
    ]
  }
{% endschema %}