<section class="custom-hero-banner">
  {% if section.settings.hero_image != blank %}
    <img
      class="custom-hero-banner__image"
      src="{{ section.settings.hero_image | image_url: width: 1920 }}"
      width="1920"
      height="1280"
      loading="lazy"
      alt="Elk with large antlers in a grassy field with cornfield in the background">
  {% endif %}

  <div class="custom-hero-banner__overlay"></div>

  <div class="custom-hero-banner__content page-width">
    {% if section.settings.heading != blank %}
      <h1 class="custom-hero-banner__heading">
        {{ section.settings.heading }}
      </h1>
    {% endif %}

    {% if section.settings.text != blank %}
      <p class="custom-hero-banner__text">
        {{ section.settings.text }}
      </p>
    {% endif %}

    {% if section.settings.button_label != blank and section.settings.button_link != blank %}
      <a href="{{ section.settings.button_link }}" class="custom-hero-banner__button">
        {{ section.settings.button_label }}
      </a>
    {% endif %}
  </div>
</section>

<style>
  .custom-hero-banner {
    position: relative;
    width: 100%;
    min-height: 630px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .custom-hero-banner__image {
    object-position: 68%;
    position: absolute;
    bottom: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }

  .custom-hero-banner__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.4);
    z-index: 2;
    pointer-events: none;
  }

  .custom-hero-banner__content {
    position: relative;
    max-width: 700px;
    padding: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    text-align: center;
  }

  .custom-hero-banner__heading {
    color: #ffffff;
    font-size: 4.7rem;
    font-weight: 300;
    line-height: 1.4;
    letter-spacing: 2px;
    margin-bottom: 16px;
    margin-top: 0;
  }

  .custom-hero-banner__text {
    color: #ffffff;
    font-size: 1.4rem;
    margin-top: 0;
    margin-bottom: 32px;
    font-weight: 400;
  }

  .custom-hero-banner__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    max-width: 220px;
    padding: 14px;
    border: 2px solid #cda34f;
    color: #cda34f;
    text-decoration: none;
    font-size: 1.1rem;
    font-weight: 600;
    transition: all 0.3s ease;
  }

  .custom-hero-banner__button:hover {
    background: #cda34f;
    color: #ffffff;
  }

  @media screen and (max-width: 767px) {

    .custom-hero-banner {
      min-height: 380px;
    }

    .custom-hero-banner__heading {
      font-size: 1.85rem;
      line-height: 1.2;
    }

    .custom-hero-banner__text {
      font-size: 1.1rem;
      padding-inline: 20px;
    }

    .custom-hero-banner__button {
      font-size: 1.1rem;
    }
  }

  @media screen and (max-width: 480px) {

    .custom-hero-banner {
      min-height: 410px;
    }

    .custom-hero-banner__heading {
      font-size: 1.72rem;
      padding-inline: 15px;
    }

    .custom-hero-banner__text {
      font-size: 1.1rem;
      padding-inline: 15px;
    }

    .custom-hero-banner__button {
      font-size: 1.15rem;
      max-width: 130px;
    }
  }
</style>

{% schema %}
  {
    "name": "Custom Hero Banner",
    "tag": "section",
    "class": "section",

    "settings": [
      {
        "type": "image_picker",
        "id": "hero_image",
        "label": "Background Image"
      },

      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "NOBLE BY NAME, QUALITY BY CHOICE."
      },

      {
        "type": "text",
        "id": "text",
        "label": "Subheading",
        "default": "Premium Elk Meat, Antler, and Supplements"
      },
      {
        "type": "text",
        "id": "button_label",
        "label": "Button Label",
        "default": "SHOP NOW"
      }, {
        "type": "url",
        "id": "button_link",
        "label": "Button Link"
      }
    ],

    "presets": [
      {
        "name": "Custom Hero Banner"
      }
    ]
  }
{% endschema %}