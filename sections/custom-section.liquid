<section class="custom-hero-banner">
  {% if section.settings.hero_image != blank %}
    <img
      class="custom-hero-banner__image"
      src="{{ section.settings.hero_image | image_url: width: 2500 }}"
      width="2500"
      height="1400"
      alt="{{ section.settings.heading | escape }}"
    >
  {% endif %}

  <div class="custom-hero-banner__overlay"></div>

  <div class="custom-hero-banner__content page-width">
    {% if section.settings.heading != blank %}
      <h1 class="custom-hero-banner__heading">
        {{ section.settings.heading }}
      </h1>
    {% endif %}

    {% if section.settings.text != blank %}
      <p class="custom-hero-banner__text">
        {{ section.settings.text }}
      </p>
    {% endif %}

    {% if section.settings.button_label != blank and section.settings.button_link != blank %}
      <a
        href="{{ section.settings.button_link }}"
        class="custom-hero-banner__button"
      >
        {{ section.settings.button_label }}
      </a>
    {% endif %}
  </div>
</section>

<style>
.custom-hero-banner {
  position: relative;
  width: 100%;
  min-height: 750px;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.custom-hero-banner__image {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.custom-hero-banner__overlay {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.35);
  z-index: 1;
}

.custom-hero-banner__content {
  position: relative;
  z-index: 2;

  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;

  text-align: center;
}

.custom-hero-banner__heading {
  color: #ffffff;
  font-size: 7rem;
  font-weight: 300;
  line-height: 1.1;
  letter-spacing: 2px;
  margin: 0;
  max-width: 1000px;
}

.custom-hero-banner__text {
  color: #ffffff;
  font-size: 2rem;
  margin-top: 2rem;
  margin-bottom: 3rem;
}

.custom-hero-banner__button {
  display: inline-flex;
  align-items: center;
  justify-content: center;

  min-width: 170px;
  min-height: 55px;

  border: 2px solid #cda34f;

  color: #cda34f;
  text-decoration: none;

  font-size: 1.7rem;
  font-weight: 600;

  transition: all .3s ease;
}

.custom-hero-banner__button:hover {
  background: #cda34f;
  color: #ffffff;
}

/* ---------- Tablet ---------- */

@media screen and (max-width: 990px) {

  .custom-hero-banner {
    min-height: 650px;
  }

  .custom-hero-banner__heading {
    font-size: 5rem;
  }

  .custom-hero-banner__text {
    font-size: 1.8rem;
  }
}

/* ---------- Mobile ---------- */

@media screen and (max-width: 768px) {

  .custom-hero-banner {
    min-height: 550px;
  }

  .custom-hero-banner__heading {
    font-size: 3.8rem;
    line-height: 1.2;
  }

  .custom-hero-banner__text {
    font-size: 1.6rem;
    padding-inline: 20px;
  }

  .custom-hero-banner__button {
    min-width: 150px;
    min-height: 50px;
    font-size: 1.5rem;
  }
}

/* ---------- iPhone 375px ---------- */

@media screen and (max-width: 480px) {

  .custom-hero-banner {
    min-height: 500px;
  }

  .custom-hero-banner__heading {
    font-size: 3rem;
    padding-inline: 15px;
  }

  .custom-hero-banner__text {
    font-size: 1.4rem;
    padding-inline: 15px;
  }

  .custom-hero-banner__button {
    min-width: 140px;
    min-height: 46px;
    font-size: 1.4rem;
  }
}
</style>

{% schema %}
{
  "name": "Custom Hero Banner",
  "tag": "section",
  "class": "section",

  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Background Image"
    },

    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "NOBLE BY NAME, QUALITY BY CHOICE."
    },

    {
      "type": "text",
      "id": "text",
      "label": "Subheading",
      "default": "Premium Elk Meat, Antler, and Supplements"
    },

    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "SHOP NOW"
    },

    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],

  "presets": [
    {
      "name": "Custom Hero Banner"
    }
  ]
}
{% endschema %}