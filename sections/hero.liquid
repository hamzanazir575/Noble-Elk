<style>

  .custom-hero-banner {
    position: relative;
    width: 100%;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 100px 20px;
  }

  .custom-hero-banner::after {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.4);
    z-index: 1;
    width: 100%;
    height: 99.5%;
  }

  .custom-hero-banner__image {
    position: absolute;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
    object-position: 68.7712% 42.929%;
  }

  .custom-hero-banner__content {
    max-width: 700px;
    z-index: 2;
    text-align: center;
  }

  .custom-hero-banner__heading {
    color: #ffffff;
    font-size: 24px;
    font-weight: 350;
    line-height: 1.2;
    margin-block: 0 16px;
  }

  .custom-hero-banner__text {
    color: #ffffff;
    font-size: 14px;
    margin-block: 0 32px;
    font-weight: 400;
    line-height: 1.5;
  }

  .custom-hero-banner__button {
    display: inline-block;
    text-transform: uppercase;
    padding: 14px;
    border: 2px solid #D3AE5D;
    color: #D3AE5D;
    text-decoration: none;
    font-size: 15px;
    font-weight: 600;
    transition: all 0.3s ease;
  }

  .custom-hero-banner__button:hover {
    background: #cda34f;
    color: #ffffff;
  }

  @media screen and (min-width: 768px) {
  .custom-hero-banner {
    padding: 162px 20px 170px;
  }

    .page-width {
      padding: 0;
    }

    .custom-hero-banner__heading {
      font-size: 61px;
    }

    .custom-hero-banner__text {
      font-size: 18px;
      letter-spacing: 0.6px;
    }
  }

</style>

<div class="custom-hero-banner">
  {% if section.settings.hero_image != blank %}
    <img
      class="custom-hero-banner__image"
      src="{{ section.settings.hero_image | image_url: width: section.settings.hero_image.width }}"
      width="1920"
      height="1280"
      loading="lazy"
      alt="Elk with large antlers in a grassy field with cornfield in the background">
  {% else %}
    {{ 'product-1' | placeholder_svg_tag }}
  {% endif %}


  <div class="custom-hero-banner__content page-width">
    {% if section.settings.heading != blank %}
      <h1 class="custom-hero-banner__heading">
        {{ section.settings.heading }}
      </h1>
    {% endif %}

    {% if section.settings.text != blank %}
      <p class="custom-hero-banner__text">
        {{ section.settings.text }}
      </p>
    {% endif %}

    {% if section.settings.button_label != blank and section.settings.button_link != blank %}
      <a href="{{ section.settings.button_link }}" class="custom-hero-banner__button">
        {{ section.settings.button_label }}
      </a>
    {% endif %}
  </div>
</div>

{% schema %}
  {
    "name": "Hero",
    "tag": "section",
    "class": "hero__section",

    "settings": [
      {
        "type": "image_picker",
        "id": "hero_image",
        "label": "Background Image"
      },

      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "NOBLE BY NAME, QUALITY BY CHOICE."
      },

      {
        "type": "text",
        "id": "text",
        "label": "Subheading",
        "default": "Premium Elk Meat, Antler, and Supplements"
      },

      {
        "type": "text",
        "id": "button_label",
        "label": "Button Label",
        "default": "SHOP NOW"
      },

      {
        "type": "url",
        "id": "button_link",
        "label": "Button Link"
      }
    ],

    "presets": [
      {
        "name": "Hero"
      }
    ]
  }
{% endschema %}