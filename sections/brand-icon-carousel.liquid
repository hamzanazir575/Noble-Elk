<style>
  .brands__container {
    background-color: #ffffff;
    overflow: hidden;
  }

  .brands__header {
    text-align: center;
    margin-bottom: 26px;
  }

  .brands__title {
    color: {{ section.settings.heading_color }};
    font-size: 12.8px;
    font-weight: 600;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0;
  }

  .brands__wrapper {
    display: flex;
    align-items: center;
    animation: brands-slide 60s linear infinite;
  }

  .brand__item {
    display: flex;
    align-items: center;
    margin-right: 100px;
    flex-shrink: 0;
  }

  .brands__icons {
    height: 52.0px;
    width: 96.0px;
    object-fit: contain;
    filter: grayscale(100%);
    transition: filter 0.3s ease;
    background-color: rgba(0, 0, 0, 0);
    border-radius: 0;
    border: 0 solid #e0e0e0;
  }

  .brands__icons:hover {
    filter: none;
  }

  @media only screen and (min-width: 768px) {
    .brands__title {
    font-size: 16px;
  }

  .brands__icons {
    height: 65px;
    width: 120px;
  }
}

  @keyframes brands-slide {
    from {
      transform: translateX(0);
    }

    to {
      transform: translateX(-50%);
    }
  }
</style>

<div class="brands__container">
  <div class="brands__header">
    <h2 class="brands__title">{{ section.settings.heading }}</h2>
  </div>
  <div class="brands__wrapper">

    {% for block in section.blocks %}
      {% if block.settings.logo != blank %}
        <div class="brand__item">
          <img
            class="brands__icons"
            src="{{ block.settings.logo |  image_url: width:  block.settings.logo.width  }}"
            width="{{ block.settings.logo.width }}"
            height="{{ block.settings.logo.height }}"
            loading="lazy"
            alt="">
        </div>
      {% else %}
        {{ 'product-1' | placeholder_svg_tag: "brand__icons" }}
      {% endif %}
    {% endfor %}
  </div>
</div>

{% schema %}
{
    "name": "Brands Marquee",
    "tag": "section",
    "class": "brands",
    "settings":[
        {
            "type": "text",
            "id": "heading",
            "label": "Title",
            "default": "find us in"
        },
        {
            "type": "color",
            "id": "heading_color",
            "label": "Heading Text Color",
            "default": "#333333"
        }
    ],
    "blocks": [
        {
            "type": "brand",
            "name": "Brand Logo",
            "settings": [
                {
                    "type": "image_picker",
                    "id": "logo",
                    "label": "Brand Logo"
                }
            ]
        }
    ],
    "max_blocks": 10,
    "presets": [
        {
            "name": "Brands Marquee",
            "blocks": [
                {
                    "type": "brand"
                },
                {
                    "type": "brand"
                },
                {
                    "type": "brand"
                },
                {
                    "type": "brand"
                },
                {
                    "type": "brand"
                },
                {
                    "type": "brand"
                },
                {
                    "type": "brand"
                },
                {
                    "type": "brand"
                }
            ]
        }
    ]
}
{% endschema %}