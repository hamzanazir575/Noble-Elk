<style>
.shopify-section.featured-product-v1 {
   background-color: rgb(185 161 108 / 9%);
}

.featured-products-v1__container {
  padding-block: 93px 203px;
  max-width: 1230px;
  margin: 0 auto;
}

.featured-products-v1__header {
  text-align: center;
}

.featured-products-v1__heading {
  margin: 0;
  font-size: 20px;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.6px;
  margin-bottom: 24px;
}

.featured-products-v1__heading::after {
  content: "";
  display: block;
  width: 40px;
  height: 4px;
  background: #cda34f;
  margin: 16px auto 0;
}

.featured-products-v1__grid {
  display: grid;
  gap: 16px;
  grid-template-columns: 1fr 1fr;
  grid-template-rows: repeat(4, 200px);
  width: 100%;

  grid-template-areas:
    "item1 item1"
    "item2 item2"
    "item3 item3"
    "item4 item4";
}

.featured-products-v1__grid img {
  width: 100%;
  height: 100%;
}

.featured-products-v1__item {
  position: relative;
  overflow: hidden;
}

.featured-products-v1__item--1 {
  grid-area: item1;
}

.featured-products-v1__item--2 {
  grid-area: item2;
}

.featured-products-v1__item--3 {
  grid-area: item3;
}

.featured-products-v1__item--4 {
  grid-area: item4;
}

.featured-products-v1__image {
  position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform .3s ease;
}

.featured-products-v1__item::before {
  content: "";
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,.5);
  z-index: 1;
  transition: background 0.3s ease;
}

.featured-products-v1__item:hover .featured-products-v1__image {
  transform: scale(1.05);
}

.featured-products-v1__item:hover::before {
  background: rgba(0,0,0,.6);
}

.featured-products-v1__content {
  position: absolute;
  inset: 0;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 20px;
}

.featured-products-v1__title {
  color: #fff;
  font-size: 32px;
  font-weight: 400;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  margin: 0;
}

@media screen and (min-width: 1024px) {
  .featured-products-v1__grid {
    grid-template-columns: 255px 1fr 1fr 1fr;
    grid-template-rows: repeat(2, 250px);
    gap: 20px;
    grid-template-areas:
      "item1 item1 item2 item3"
      "item1 item1 item4 item4";
  }

  .featured-products-v1__title {
    font-size: 32px;
  }

  .featured-products-v1__heading {
    margin-bottom: 48px;
    font-size: 24px;
}
}
</style>

<div class="featured-products-v1__container">

    <div class="featured-products-v1__header">
      <h2 class="featured-products-v1__heading">
        {{ section.settings.heading }}
      </h2>
    </div>
    <div class="featured-products-v1__grid">

      {% for block in section.blocks %}

        {% assign product = block.settings.product %}

        {% if product != blank %}
          <a
            href="{{ product.url }}"
            class="featured-products-v1__item featured-products-v1__item--{{ forloop.index }}"
          >
            {% if product.featured_image %}
              <img
                class="featured-products-v1__image"
                src="{{ product.featured_image | image_url: width: product.featured_image.width}}"
                alt="{{ product.title }}"
                loading="lazy"
                width="{{product.featured_image.width}}"
                height="{{product.featured_image.height}}"
              >
              {% else %}
              {{ 'product-1' | placeholder_svg_tag: 'featured-logo__placeholder' }}
            {% endif %}

            <div class="featured-products-v1__content">
              <h3 class="featured-products-v1__title">

                {% if block.settings.custom_title != blank %}
                  {{ block.settings.custom_title }}
                {% else %}
                  {{ product.title }}
                {% endif %}

              </h3>
            </div>
          </a>

        {% endif %}

      {% endfor %}
    </div>
</div>

{% schema %}
{
  "name": "Featured Products v1",
  "tag": "section",
  "class": "featured-product-v1",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Featured Products"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select Product"
        },
        {
          "type": "text",
          "id": "custom_title",
          "label": "Custom Title"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Featured Products v1"
    }
  ]
}
{% endschema %}