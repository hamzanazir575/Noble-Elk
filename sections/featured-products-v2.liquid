<style>

.featured-products__container {
  padding: 80px 0px;
  background: #fff;
  max-width: 1230px;
  margin: 0 auto;
}

.featured-products__header {
  text-align: center;
  margin-bottom: 50px;
}

.featured-products__heading {
  margin: 0;
  font-size: 42px;
  text-transform: uppercase;
  letter-spacing: 2px;
}

.featured-products__heading::after {
  content: "";
  display: block;
  width: 60px;
  height: 4px;
  background: #cda34f;
  margin: 20px auto 0;
}

.featured-products__grid {
  display: grid;
  gap: 24px;
  grid-template-columns: 1fr 1fr;
  grid-template-rows: 320px 320px;
  width: 100%;

  grid-template-areas:
    "item1 item1"
    "item2 item2"
    "item3 item3"
    "item4 item4";
}

.featured-products__item {
  position: relative;
  overflow: hidden;
}

.featured-products__item--1 {
  grid-area: item1;
}

.featured-products__item--2 {
  grid-area: item2;
}

.featured-products__item--3 {
  grid-area: item3;
}

.featured-products__item--4 {
  grid-area: item4;
}

.featured-products__image {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.featured-products__item::before {
  content: "";
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,.35);
  z-index: 1;
}

.featured-products__content {
  position: absolute;
  inset: 0;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 20px;
}

.featured-products__title {
  color: #fff;
  font-size: 34px;
  font-weight: 300;
  text-transform: uppercase;
  letter-spacing: 2px;
  margin: 0;
}

/* Desktop */

@media screen and (min-width: 990px) {

  .featured-products__grid {
    grid-template-columns: repeat(4, 1fr);

    grid-template-areas:
      "item1 item1 item2 item3"
      "item1 item1 item4 item4";
  }

  .featured-products__title {
    font-size: 48px;
  }
}
</style>
<div class="featured-products__container">

    <div class="featured-products__header">
      <h2 class="featured-products__heading">
        {{ section.settings.heading }}
      </h2>
    </div>

    <div class="featured-products__grid">

      {% for block in section.blocks %}

        {% assign product = block.settings.product %}

        {% if product != blank %}

          <a
            href="{{ product.url }}"
            class="featured-products__item featured-products__item--{{ forloop.index }}"
          >

            {% if product.featured_image %}
              <img
                class="featured-products__image"
                src="{{ product.featured_image | image_url: width: product.featured_image.width}}"
                alt="{{ product.title }}"
                loading="lazy"
                width="1800"
                height="1800"
              >
              {% else %}
              {{ 'product-1' | placeholder_svg_tag: 'featured-logo__placeholder' }}
            {% endif %}

            <div class="featured-products__content">
              <h3 class="featured-products__title">

                {% if block.settings.custom_title != blank %}
                  {{ block.settings.custom_title }}
                {% else %}
                  {{ product.title }}
                {% endif %}

              </h3>
            </div>

          </a>

        {% endif %}

      {% endfor %}
    </div>

</div>

{% schema %}
{
  "name": "Featured Products v2",
  "tag": "section",
  "class": "featured-product__grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Featured Products"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select Product"
        },
        {
          "type": "text",
          "id": "custom_title",
          "label": "Custom Title"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Featured Products v2"
    }
  ]
}
{% endschema %}