{% doc %}
  @prompt
    Create a custom CSS block that targets the specific text block with ID "template--19355553398851__image_with_text_y6YxEi__text_AdeaDt" inside section "template--19355553398851__image_with_text_y6YxEi" and sets its font-size to 20px. The CSS should be scoped so it only affects this specific block and does not impact any other text on the store.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-custom-css-{{ ai_gen_id }} {
    display: block;
  }

  #template--19355553398851__image_with_text_y6YxEi #shopify-block-template--19355553398851__image_with_text_y6YxEi__text_AdeaDt {
    font-size: 20px !important;
  }
{% endstyle %}

<div class="ai-custom-css-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <style>
    #template--19355553398851__image_with_text_y6YxEi #shopify-block-template--19355553398851__image_with_text_y6YxEi__text_AdeaDt {
      font-size: {{ block.settings.font_size }}px !important;
    }
  </style>
</div>

{% schema %}
{
  "name": "Custom CSS for text block",
  "settings": [
    {
      "type": "header",
      "content": "Target block styling"
    },
    {
      "type": "paragraph",
      "content": "This block targets text block ID: template--19355553398851__image_with_text_y6YxEi__text_AdeaDt"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 10,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Custom CSS for text block"
    }
  ]
}
{% endschema %}
